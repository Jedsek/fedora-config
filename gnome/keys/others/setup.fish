gsettings set org.gnome.shell.keybindings toggle-message-tray            "['<Super>n']"                   ## Default:  Super+V, Super+M
gsettings set org.gnome.settings-daemon.plugins.media-keys screensaver   "['<Super>Escape']"              ## Default:  Super+L
gsettings set org.gnome.desktop.wm.keybindings panel-run-dialog          "['<Super>c']"                   ## Default:  Alt+F2

gsettings set org.gnome.desktop.wm.keybindings switch-input-source       "['XF86Keyboard']"